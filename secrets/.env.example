ates to # AWS credentials for project S3 bucket (shared key from admin)
# Copy this file to .env and replace the placeholders with the values you received.
# Do not commit .env to git.

AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_DEFAULT_REGION=us-east-2

# Optional: override bucket/prefix (scripts use these defaults if not set)
# IRS_990_S3_BUCKET=swb-321-irs990-teos
# IRS_990_S3_PREFIX=bronze/irs990/teos_xml
