{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListBucketsForConsole",
      "Effect": "Allow",
      "Action": "s3:ListAllMyBuckets",
      "Resource": "*"
    },
    {
      "Sid": "FullAccessToOneBucket",
      "Effect": "Allow",
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::swb-321-irs990-teos",
        "arn:aws:s3:::swb-321-irs990-teos/*"
      ]
    },
    {
      "Sid": "DenyDeleteBucket",
      "Effect": "Deny",
      "Action": "s3:DeleteBucket",
      "Resource": "arn:aws:s3:::swb-321-irs990-teos"
    }
  ]
}
